#!/bin/sh
# Restart the local app after git pull when backend/frontend source changed.
# This post-merge convenience does not replace the pre-merge gate documented in
# docs/workflow.md: backend pytest and the production frontend build must pass.

ROOT="$(git rev-parse --show-toplevel)"
CHANGED="$(git diff-tree -r --name-only --no-commit-id ORIG_HEAD HEAD 2>/dev/null || true)"

needs_restart=false
for file in $CHANGED; do
  case "$file" in
    backend/*|frontend/*|run.ps1|scripts/restart.ps1)
      needs_restart=true
      break
      ;;
  esac
done

if [ "$needs_restart" = "true" ]; then
  echo "App source updated — restarting local server in the background..."
  powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$ROOT/scripts/restart.ps1" -Background
fi
